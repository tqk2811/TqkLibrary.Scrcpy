<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
	<!--https://docs.microsoft.com/en-us/nuget/reference/nuspec-->
	<metadata>
		<id>TqkLibrary.Scrcpy.Wpf</id>
		<version>$version$</version>
		<description>WPF controls for TqkLibrary.Scrcpy - stream screen and control android devices</description>
		<releaseNotes>https://github.com/tqk2811/TqkLibrary.Scrcpy/releases</releaseNotes>
		<authors>tqk2811</authors>
		<projectUrl>https://github.com/tqk2811/TqkLibrary.Scrcpy</projectUrl>
		<repository type="git" url="https://github.com/tqk2811/TqkLibrary.Scrcpy.git"/>
		<license type="expression">MIT</license>
		<readme>docs\README.md</readme>
		<dependencies>
			<group targetFramework="net462">
				<dependency id="TqkLibrary.Scrcpy" version="$version$" />
				<dependency id="TqkLibrary.Wpf.Interop.DirectX" version="1.1.21" />
			</group>
			<group targetFramework="net6.0-windows7.0">
				<dependency id="TqkLibrary.Scrcpy" version="$version$" />
				<dependency id="TqkLibrary.Wpf.Interop.DirectX" version="1.1.21" />
			</group>
			<group targetFramework="net7.0-windows7.0">
				<dependency id="TqkLibrary.Scrcpy" version="$version$" />
				<dependency id="TqkLibrary.Wpf.Interop.DirectX" version="1.1.21" />
			</group>
		</dependencies>
	</metadata>

	<files>
		<file src="..\README.md" target="docs\README.md" />

		<file src="bin\Release\**\TqkLibrary.Scrcpy.Wpf.dll" target="lib\" />
		<file src="bin\Release\**\TqkLibrary.Scrcpy.Wpf.pdb" target="lib\" />
		<file src="bin\Release\**\TqkLibrary.Scrcpy.Wpf.xml" target="lib\" />
	</files>
</package>